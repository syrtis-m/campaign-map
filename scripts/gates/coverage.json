{
  "_comment": "Change-scoped gating manifest. Maps each live SMOKE gate to the source globs it exercises, so `npm run gates:changed` runs only the gates whose coverage intersects a diff. The board (`npm run board`) = prologue (unit/fuzz/tsc/build) + these five gates. Every retired live gate has a prove-by-breaking record in review/030B-break-proofs.md; its coverage lives headless (generator suites + testkit invariants + metric bands + perceptual goldens + styleGolden). Globs err toward OVER-inclusion. `determinismCritical` paths escalate to the full board.",
  "determinismCritical": [
    "src/gen/region.ts",
    "src/gen/rng.ts",
    "**/clip.ts",
    "src/model/tileCache.ts"
  ],
  "gates": {
    "smokeBoot": {
      "script": "scripts/gates/smokeBoot.ts",
      "globs": [
        "src/main.ts",
        "src/view/MapView.ts",
        "src/map/themes/**",
        "src/map/theme.ts",
        "src/map/glyphs.ts",
        "src/map/pmtilesVaultProtocol.ts",
        "src/map/campaignDemProtocol.ts",
        "src/model/campaignConfig.ts"
      ]
    },
    "phase1": {
      "script": "scripts/gates/phase1.ts",
      "globs": [
        "src/main.ts",
        "src/view/**",
        "src/vault/**",
        "src/model/locationNote.ts",
        "src/model/connections.ts",
        "src/model/mutationLog.ts",
        "src/map/locationIndex.ts"
      ]
    },
    "smokeProcgen": {
      "script": "scripts/gates/smokeProcgen.ts",
      "globs": [
        "src/gen/**",
        "src/controller/**",
        "src/map/generation/**",
        "src/map/treeGlyphs.ts",
        "src/model/fabric.ts",
        "src/model/tileCache.ts",
        "src/view/MapView.ts",
        "src/view/SketchController.ts"
      ]
    },
    "version29": {
      "script": "scripts/gates/version29.ts",
      "globs": [
        "src/gen/procgen/registry.ts",
        "src/gen/cache/fingerprint.ts",
        "src/controller/MapController.ts",
        "src/model/fabric.ts",
        "src/view/MapView.ts",
        "src/main.ts"
      ]
    },
    "phase5": {
      "script": "scripts/gates/phase5.ts",
      "globs": [
        "src/map/posterExport.ts",
        "src/map/atlasExport.ts",
        "src/model/sessionPath.ts",
        "src/model/connections.ts",
        "src/model/importGeojson.ts",
        "src/gen/populate.ts",
        "src/view/MapView.ts"
      ]
    }
  }
}