{
  "name": "campaign-map",
  "version": "0.0.1",
  "description": "Google-Maps-style map tab for tabletop campaigns — Obsidian plugin",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs watch",
    "build": "tsc --noEmit && node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit",
    "fonts:fetch": "scripts/fetch-fonts.sh",
    "fonts:build": "npm run fonts:fetch && node scripts/build-glyphs.mjs",
    "test": "vitest run --config vitest.config.ts",
    "test:fuzz": "vitest run --config vitest.fuzz.config.ts",
    "test:watch": "vitest",
    "test:app": "tsx scripts/test-app.ts",
    "gates:changed": "tsx scripts/changed-gates.ts",
    "board": "tsx scripts/board.ts",
    "soak": "tsx scripts/rendererSoak.ts",
    "playground": "node playground/serve.mjs"
  },
  "devDependencies": {
    "@maplibre/maplibre-gl-style-spec": "^20.4.0",
    "@types/d3-delaunay": "^6.0.4",
    "@types/node": "^22.10.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.24.0",
    "fontnik": "^0.7.7",
    "obsidian": "^1.7.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "d3-delaunay": "^6.0.4",
    "flatbush": "^4.4.0",
    "maplibre-gl": "^4.7.1",
    "minisearch": "^7.1.0",
    "pdf-lib": "^1.17.1",
    "pmtiles": "^3.2.0",
    "zod": "^3.24.0"
  }
}
